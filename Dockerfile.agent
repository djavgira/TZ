# Stage 1: Build (same as Dockerfile)
FROM golang:1.24-alpine AS builder
RUN apk add --no-cache git ca-certificates
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download && go mod verify
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 \
    go build -trimpath -ldflags="-s -w" -o /tz ./cmd/tz/

# Stage 2: Runtime
FROM alpine:3.21
RUN apk add --no-cache ca-certificates tzdata && \
    adduser -D -u 65532 -s /sbin/nologin tz
COPY --from=builder /tz /usr/local/bin/tz
COPY configs/tz.agent.yaml /etc/tz/tz.yaml
USER tz
ENTRYPOINT ["tz", "agent", "--config", "/etc/tz/tz.yaml"]
